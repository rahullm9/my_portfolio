{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/frontend/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/dist/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
